# Copiez ce fichier en ".env" pour le développement local (ne jamais commiter le ".env" réel)

SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=sqlite:///vcsoy_dev.db

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 1 = permet une connexion simplifiée par simple e-mail, sans Google (pratique en local)
# 0 = désactive cette porte d'entrée (à utiliser en production une fois Google validé)
ALLOW_DEV_LOGIN=1

# Liste blanche des adresses autorisées à se connecter (séparées par des virgules).
# S'applique à la fois à la connexion Google et à la connexion simplifiée.
# Laisser vide = aucune restriction (déconseillé en production).
# Exemple : ALLOWED_EMAILS=didier@escda.ca,alexandra@escda.ca,collegue@gmail.com
ALLOWED_EMAILS=

# Adresses ayant les droits administrateur (Administration, Annuler un
# fichier), séparées par des virgules. Un administrateur peut ensuite en
# promouvoir d'autres depuis l'écran Administration.
# Exemple : ADMIN_EMAILS=didier@escda.ca
ADMIN_EMAILS=
